{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "go: build backend",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-o",
        "${workspaceFolder}/bin/task-manager-backend.exe",
        "${workspaceFolder}/cmd/main.go"
      ],
      "group": "build",
      "problemMatcher": "$go"
    },
    {
      "label": "go: run backend",
      "type": "shell",
      "command": "${workspaceFolder}/bin/task-manager-backend.exe",
      "dependsOn": "go: build backend",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
